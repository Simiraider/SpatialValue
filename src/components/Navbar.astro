---
import Logo from "./Logo.astro";
import sql from "../Backend/carga.js";

const userIdCookie = Astro.cookies.get("usuario_id");
let username = null;

if (userIdCookie?.value) {
  try {
    const res = await sql`SELECT nombre FROM usuarios WHERE id = ${userIdCookie.value}`;
    if (res.length > 0) {
      username = res[0].nombre;
    }
  } catch (error) {
    console.error("Error al obtener nombre de usuario:", error);
  }
}
---

<header class="navbar">
  <div class="navbar-inner">
    <a href="/" class="logo">
      <Logo />
      <span>SpatialValue</span>
    </a>

    <nav aria-label="Principal">
      <ul class="nav-links">
        <li><a href="#quienes-somos">Quienes Somos</a></li>
        <li><a href="#sobre-tasaciones">Sobre las Tasaciones</a></li>
      </ul>
    </nav>

    <div class="nav-right">
      {username ? (
        <a href="/dashboard" class="nav-login">Hola, {username}</a>
      ) : (
        <a href="/login" class="nav-login">Iniciar Sesión</a>
      )}
      <a href={username ? "/tasacion" : "/login"} class="button-primary">Tasa tu propiedad</a>
    </div>
  </div>
</header>
