---
const partners = [
  { name: "Tribunal de Tasaciones" },
  { name: "Colegio de Corredores" },
  { name: "Colegio de Arquitectos" },
];
---

<section class="social-proof" aria-label="Confianza">
  <div class="social-proof-inner">
    <p class="social-proof-metric">
      <strong>Margen de error &lt; 3%</strong> · respaldado por datos de mercado
    </p>
    <div class="logo-row" role="list">
      {partners.map((partner) => (
        <span class="partner-placeholder" role="listitem" title={partner.name}>
          {partner.name}
        </span>
      ))}
    </div>
  </div>
</section>
