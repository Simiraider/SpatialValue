---
/**
 * Logo de marca. Pon tu archivo en public/logo.svg (o .png / .webp).
 * Si usás otro nombre, cambiá `src` abajo.
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<img
  src="/logo.svg"
  alt="SpatialValue"
  class:list={["logo-img", className]}
/>
