---
interface Props {
  padding?: 'sm' | 'md' | 'lg';
  hover?: boolean;
}

const {
  padding = 'md',
  hover = false,
} = Astro.props;
---

<div class:list={['card', `card-${padding}`, { 'card-hover': hover }]}>
  <slot />
</div>

<style>
  .card {
    background: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 12px;
  }

  .card-sm {
    padding: 1rem;
  }

  .card-md {
    padding: 1.5rem;
  }

  .card-lg {
    padding: 2rem;
  }

  .card-hover {
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .card-hover:hover {
    border-color: #113a77;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
</style>
