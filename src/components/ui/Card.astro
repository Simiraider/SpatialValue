---
interface Props {
  padding?: 'sm' | 'md' | 'lg';
  hover?: boolean;
}

const {
  padding = 'md',
  hover = false,
} = Astro.props;
---

<div class:list={['card', `card-${padding}`, { 'card-hover': hover }]}>
  <slot />
</div>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .card-sm {
    padding: 1rem;
  }

  .card-md {
    padding: 1.5rem;
  }

  .card-lg {
    padding: 2rem;
  }

  .card-hover {
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .card-hover:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }
</style>
