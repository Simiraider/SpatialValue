---
interface Props {
  variant?: 'success' | 'warning' | 'error' | 'info' | 'neutral';
}

const {
  variant = 'neutral',
} = Astro.props;
---

<span class:list={['badge', `badge-${variant}`]}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
  }

  .badge-success {
    background: #dcfce7;
    color: #166534;
  }

  .badge-warning {
    background: #fef9c3;
    color: #854d0e;
  }

  .badge-error {
    background: #fee2e2;
    color: #991b1b;
  }

  .badge-info {
    background: #dbeafe;
    color: #1e40af;
  }

  .badge-neutral {
    background: #f4f4f5;
    color: #71717a;
  }
</style>
