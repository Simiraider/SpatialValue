---
interface Props {
  variant?: 'primary' | 'secondary' | 'danger' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  fullWidth?: boolean;
  disabled?: boolean;
}

const {
  variant = 'primary',
  size = 'md',
  type = 'button',
  href,
  fullWidth = false,
  disabled = false,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  type={!href ? type : undefined}
  disabled={!href ? disabled : undefined}
  class:list={['btn', `btn-${variant}`, `btn-${size}`, { 'btn-full': fullWidth }]}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s ease;
    border-radius: 8px;
    line-height: 1;
  }

  .btn:disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    height: 2rem;
  }

  .btn-md {
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    height: 2.5rem;
  }

  .btn-lg {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    height: 3rem;
  }

  .btn-primary {
    background: #113a77;
    color: #ffffff;
  }

  .btn-primary:hover:not(:disabled) {
    background: #161fa3c0;
  }

  .btn-secondary {
    background: #f4f4f5;
    color: #18181b;
  }

  .btn-secondary:hover:not(:disabled) {
    background: #e4e4e7;
  }

  .btn-danger {
    background: #dc2626;
    color: #ffffff;
  }

  .btn-danger:hover:not(:disabled) {
    background: #b91c1c;
  }

  .btn-ghost {
    background: transparent;
    color: #71717a;
  }

  .btn-ghost:hover:not(:disabled) {
    background: #f4f4f5;
    color: #18181b;
  }

  .btn-full {
    width: 100%;
  }
</style>
