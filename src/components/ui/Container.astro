---
interface Props {
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
}

const {
  maxWidth = 'xl',
} = Astro.props;

const widths = {
  sm: '40rem',
  md: '48rem',
  lg: '64rem',
  xl: '80rem',
  full: '100%',
};
---

<div class="container" style={`max-width: ${widths[maxWidth]}`}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }
  }
</style>
