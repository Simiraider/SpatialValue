---
interface Props {
  type?: string;
  name?: string;
  id: string;
  label?: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  error?: string;
  value?: string;
}

const {
  type = 'text',
  name,
  id,
  label,
  placeholder,
  required = false,
  disabled = false,
  error,
  value,
} = Astro.props;
---

<div class="input-group">
  {label && <label for={id} class="input-label">{label}</label>}
  <input
    {id}
    {name}
    {type}
    {placeholder}
    {value}
    required={required}
    disabled={disabled}
    class:list={['input', { 'input-error': error }]}
    aria-invalid={error ? 'true' : undefined}
    aria-describedby={error ? `${id}-error` : undefined}
  />
  {error && <span id={`${id}-error`} class="input-error-msg" role="alert">{error}</span>}
</div>

<style>
  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .input-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #18181b;
  }

  .input {
    padding: 0.625rem 0.875rem;
    border: 1px solid #d4d4d8;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #18181b;
    background: #ffffff;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    outline: none;
  }

  .input::placeholder {
    color: #a1a1aa;
  }

  .input:focus {
    border-color: #113a77;
    box-shadow: 0 0 0 2px rgba(17, 58, 119, 0.15);
  }

  .input:disabled {
    background: #f4f4f5;
    color: #a1a1aa;
    cursor: not-allowed;
  }

  .input.input-error {
    border-color: #dc2626;
  }

  .input.input-error:focus {
    box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.15);
  }

  .input-error-msg {
    font-size: 0.75rem;
    color: #dc2626;
  }
</style>
