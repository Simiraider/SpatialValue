---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import { DashboardCard } from '../components/DashboardCard';
import { PriceHistoryChart, MarketComparisonChart } from '../components/Charts';
import { Button } from '../components/ui/Button';
import { Building2, DollarSign, Activity, TrendingUp, Download, ArrowUpRight } from 'lucide-react';

const comparables = [
  { address: 'Av. Libertador 1234, 4B', price: '$135,000', size: '110 m²', date: 'Hace 2 días' },
  { address: 'Av. Libertador 1500, 2A', price: '$128,500', size: '105 m²', date: 'Hace 1 semana' },
  { address: 'Olleros 1800, 8C', price: '$142,000', size: '115 m²', date: 'Hace 2 semanas' },
  { address: 'Soldado de la Indep. 900', price: '$130,000', size: '108 m²', date: 'Hace 1 mes' },
];
---

<Layout title="Dashboard de Tasación">
  <div class="min-h-screen bg-slate-50 flex flex-col">
    <Navbar client:load />
    
    <div class="flex-1 container mx-auto px-4 py-8 max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold text-slate-900">Reporte de Tasación</h1>
          <p class="text-slate-500 mt-1 flex items-center gap-2">
            <Building2 className="h-4 w-4" />
            Av. Libertador 1200, Palermo, CABA
          </p>
        </div>
        <div class="flex items-center gap-3">
          <Button variant="outline" className="bg-white">
            <Download className="mr-2 h-4 w-4" />
            Exportar PDF
          </Button>
          <Button>
            Guardar Tasación
          </Button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <DashboardCard 
          title="Valor Estimado" 
          value="$132,500" 
          icon={DollarSign}
          trend={{ value: 2.4, label: "vs mes anterior", isPositive: true }}
        />
        <DashboardCard 
          title="Valor por m²" 
          value="$3,154" 
          icon={Activity}
          description="Promedio para la zona de Palermo"
        />
        <DashboardCard 
          title="Confianza del Modelo" 
          value="94%" 
          icon={TrendingUp}
          description="Basado en 45 comparables cercanos"
        />
        <DashboardCard 
          title="Tiempo Promedio de Venta" 
          value="45 Días" 
          icon={Activity}
          trend={{ value: 12, label: "más rápido que CABA", isPositive: true }}
        />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
            <div class="mb-4">
              <h3 class="text-lg font-semibold text-slate-900">Evolución Histórica del Precio</h3>
              <p class="text-sm text-slate-500">Comportamiento del mercado en los últimos 6 meses</p>
            </div>
            <PriceHistoryChart client:load />
          </div>

          <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
            <div class="mb-4">
              <h3 class="text-lg font-semibold text-slate-900">Comparativa por Barrio ($/m²)</h3>
              <p class="text-sm text-slate-500">Zonas aledañas de interés</p>
            </div>
            <MarketComparisonChart client:load />
          </div>
        </div>

        <div class="space-y-8">
          <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900 mb-4">Propiedades Comparables</h3>
            <div class="space-y-4">
              {comparables.map((comp, i) => (
                <div class="flex items-center justify-between p-3 rounded-lg border border-slate-100 hover:bg-slate-50 transition-colors">
                  <div>
                    <p class="font-medium text-slate-900 text-sm">{comp.address}</p>
                    <div class="flex items-center gap-3 mt-1 text-xs text-slate-500">
                      <span>{comp.size}</span>
                      <span>•</span>
                      <span>{comp.date}</span>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="font-bold text-slate-900">{comp.price}</p>
                    <a href="#" class="text-xs text-primary-600 hover:text-primary-700 flex items-center justify-end mt-1">
                      Ver detalle <ArrowUpRight className="h-3 w-3 ml-1" />
                    </a>
                  </div>
                </div>
              ))}
            </div>
            <Button variant="ghost" className="w-full mt-4 text-sm">
              Ver todos los comparables
            </Button>
          </div>

          <div class="bg-gradient-to-br from-primary-900 to-primary-700 rounded-xl p-6 shadow-sm text-white">
            <h3 class="text-lg font-semibold mb-2">Recomendación IA</h3>
            <p class="text-primary-100 text-sm leading-relaxed mb-4">
              El mercado actual en Palermo presenta una alta demanda para unidades de esta tipología. Sugerimos un precio de publicación de $135,000 para permitir un margen de negociación del 3-5%, cerrando cercano al valor estimado de $132,500.
            </p>
            <Button variant="secondary" className="w-full bg-white text-primary-900 hover:bg-slate-100">
              Ajustar Estrategia
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
