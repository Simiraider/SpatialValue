---
import Layout from '../layouts/Layout.astro';
import { PropertyForm } from '../components/PropertyForm';
import '../styles/tasacion.css';
---

<Layout title="Nueva Tasación">
  <header class="TasacionPage-header">
    <div class="TasacionPage-headerInner">
      <a href="/dashboard" class="TasacionPage-brand">SpatialValue</a>
      <span class="TasacionPage-subtitle">Nueva tasación</span>
    </div>
  </header>

  <main class="TasacionPage-main">
    <div class="TasacionPage-card">
      <PropertyForm client:load />
    </div>
  </main>
</Layout>
