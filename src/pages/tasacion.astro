---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Tasá tu Propiedad">
  <Navbar />
  <main class="landing-main">
    <section class="tasacion-intro">
      <h1 class="tasacion-title">Tasá tu Propiedad</h1>

      <div class="tasacion-cards">
        <div class="tasacion-card-item">
          <div class="tasacion-card-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <p class="tasacion-card-text">Respondé simples preguntas</p>
        </div>

        <div class="tasacion-card-item">
          <div class="tasacion-card-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <p class="tasacion-card-text">Usá tus imágenes</p>
        </div>

        <div class="tasacion-card-item">
          <div class="tasacion-card-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <p class="tasacion-card-text">Gozá de rapidez y precisión</p>
        </div>
      </div>

      <p class="tasacion-subtitle">Prepará tus imágenes y conseguí tu análisis detallado</p>

      <a href="/formulario" class="tasacion-cta">Comenzá a tasar</a>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .landing-main {
    min-height: calc(100vh - 4rem - 4rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .tasacion-intro {
    max-width: 960px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .tasacion-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #0F172A;
    margin: 0 0 2.5rem;
    letter-spacing: -0.02em;
  }

  .tasacion-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    width: 100%;
    margin-bottom: 2rem;
  }

  .tasacion-card-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2.5rem 1.5rem;
    background: #ffffff;
    border: 1px solid #E5E7EB;
    border-radius: 1rem;
    transition: box-shadow 0.2s, border-color 0.2s;
    min-height: 240px;
    justify-content: center;
  }

  .tasacion-card-item:hover {
    border-color: #93c5fd;
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.08);
  }

  .tasacion-card-icon {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: #eff6ff;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tasacion-card-text {
    font-size: 1rem;
    font-weight: 600;
    color: #0F172A;
    margin: 0;
    line-height: 1.4;
  }

  .tasacion-subtitle {
    font-size: 1rem;
    font-style: italic;
    color: #6b7280;
    margin: 0 0 2.5rem;
  }

  .tasacion-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 2.5rem;
    background: #2563eb;
    color: #ffffff;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 0.5rem;
    transition: background 0.15s;
  }

  .tasacion-cta:hover {
    background: #1d4ed8;
  }

  @media (max-width: 768px) {
    .tasacion-cards {
      grid-template-columns: 1fr;
      max-width: 28rem;
    }

    .tasacion-card-item {
      min-height: 160px;
      padding: 1.5rem;
    }
  }
</style>
