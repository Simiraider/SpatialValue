---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/ui/Button';
import { Input } from '../components/ui/Input';
import Logo from '../components/Logo.astro';
import '../styles/login.css';
---

<Layout title="Iniciar Sesión">
  <div class="LoginPage">
    <div class="LoginPage-inner">
      <header class="LoginPage-header">
        <a href="/" class="LoginPage-logo">
          <Logo />
        </a>
        <h1 class="LoginPage-title">Iniciar sesión</h1>
      </header>

      <div class="LoginPage-card">
        <form class="LoginPage-form" action="/dashboard" method="GET">
          <Input
            label="Usuario / Mail"
            type="text"
            placeholder="usuario@gmail.com"
            required
          />
          <Input label="Contraseña" type="password" placeholder="••••••••" required />

          <Button type="submit" fullWidth client:load>
            Ingresar
          </Button>
        </form>

        <p class="LoginPage-footer">
          Si no estás iniciado sesión,{' '}
          <a href="#" class="LoginPage-link">
            registrate
          </a>
        </p>

        <div class="LoginPage-google">
          <Button variant="outline" fullWidth type="button" client:load>
            Acceso con Google
          </Button>
        </div>
      </div>
    </div>
  </div>
</Layout>

