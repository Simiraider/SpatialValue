---
import Layout from "../layouts/Layout.astro";
import { Button } from "../components/ui/Button";
import { Input } from "../components/ui/Input";
import Logo from "../components/Logo.astro";
---

<Layout title="Iniciar Sesión">
  <div class="min-h-screen flex items-center justify-center p-4 bg-[#F8FAFC] bg-[url('/bg-logo.png')] bg-center bg-no-repeat bg-cover">
    <div class="w-full max-w-md bg-[#575656] text-white rounded-[2rem] p-8 sm:p-10 shadow-2xl relative overflow-hidden">
      <header class="mb-8 text-center flex flex-col items-center">
        <a href="/" class="text-white mb-4 block scale-125">
          <Logo />
        </a>
        <h1 class="text-2xl font-bold text-white mb-2">Iniciar sesión</h1>
        <p class="text-slate-400 text-sm" id="mensaje-estado" role="note">
          Ingresá tus credenciales para conectar a la base de datos
        </p>
      </header>

      <form class="flex flex-col gap-5" id="loginForm">
        <div class="text-slate-300">
          <Input
            id="emailInput"
            label="Usuario / Mail"
            type="email"
            placeholder="usuario@gmail.com"
            autoComplete="email"
            required
            client:load
            className="text-slate-900"
          />
        </div>
        <div class="text-slate-300">
          <Input
            id="passwordInput"
            label="Contraseña"
            type="password"
            placeholder="••••••••"
            autoComplete="current-password"
            required
            client:load
            className="text-slate-900"
          />
        </div>

        <div class="mt-2">
          <Button type="submit" fullWidth variant="secondary" client:load>Ingresar</Button>
        </div>
      </form>

      <p class="mt-8 text-center text-slate-400 text-sm">
        ¿No tenés cuenta?{" "}
        <a href="/registro" class="text-cyan-400 font-medium hover:text-cyan-300 transition-colors">Registrate</a>
      </p>

      <div class="mt-6 pt-6 border-t border-slate-300">
        <Button
          variant="outline"
          fullWidth
          type="button"
          disabled
          client:load
          className="text-white border-slate-700 bg-slate-800/50 hover:bg-slate-800 hover:text-white"
        >
          Acceso con Google (próximamente)
        </Button>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('loginForm') as HTMLFormElement;
    const mensajeEstado = document.getElementById('mensaje-estado') as HTMLElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailElement = document.getElementById('emailInput') as HTMLInputElement;
      const passwordElement = document.getElementById('passwordInput') as HTMLInputElement;

      const body = {
        email: emailElement.value,
        contraseña: passwordElement.value
      };

      try {
        mensajeEstado.innerText = "Verificando credenciales...";
        mensajeEstado.style.color = "#06b6d4"; // cyan-500

        const res = await fetch('/Apis/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });

        if (!res.ok) {
          mensajeEstado.innerText = "⚠ Backend no disponible — modo demo: redirigiendo...";
          mensajeEstado.style.color = "#f59e0b";
          document.cookie = "usuario_id=demo-user; path=/";
          setTimeout(() => { window.location.href = '/dashboard'; }, 1000);
          return;
        }

        const data = await res.json();

        if (res.ok && data.success) {
          mensajeEstado.innerText = "¡Éxito! Redirigiendo...";
          mensajeEstado.style.color = "#10b981";
          window.location.href = '/';
        } else {
          mensajeEstado.innerText = `❌ ${data.error || 'Error al iniciar sesión'}`;
          mensajeEstado.style.color = "#ef4444";
        }

      } catch (error) {
        console.error("Error en la petición:", error);
        mensajeEstado.innerText = "⚠ Backend no disponible — modo demo: redirigiendo...";
        mensajeEstado.style.color = "#f59e0b";
        document.cookie = "usuario_id=demo-user; path=/";
        setTimeout(() => { window.location.href = '/dashboard'; }, 1000);
      }
    });
  </script>
</Layout>
