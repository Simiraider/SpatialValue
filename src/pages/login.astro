---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/ui/Button';
import { Input } from '../components/ui/Input';
import Logo from '../components/Logo.astro';
---

<Layout title="Iniciar Sesión">
  <div class="flex min-h-screen flex-col justify-center bg-slate-50 px-4 py-12">
    <div class="mx-auto w-full max-w-md">
      <div class="mb-8 flex flex-col items-center text-center">
        <a href="/" class="mb-4 flex items-center gap-2 font-bold text-slate-900 no-underline">
          <Logo />
        </a>
        <h1 class="text-2xl font-bold text-slate-900">Iniciar sesión</h1>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <form class="space-y-5" action="/dashboard" method="GET">
          <Input
            label="Usuario / Mail"
            type="text"
            placeholder="usuario@gmail.com"
            required
          />
          <Input label="Contraseña" type="password" placeholder="••••••••" required />

          <Button type="submit" className="w-full">
            Ingresar
          </Button>
        </form>

        <p class="mt-6 text-center text-sm text-slate-600">
          Si no estás iniciado sesión,{' '}
          <a href="#" class="font-medium text-primary-600 hover:text-primary-500">
            registrate
          </a>
        </p>

        <div class="mt-6">
          <Button variant="outline" className="w-full" type="button">
            Acceso con Google
          </Button>
        </div>
      </div>
    </div>
  </div>
</Layout>
