---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/ui/Button';
import { Input } from '../components/ui/Input';
import Logo from '../components/Logo.astro';
import '../styles/login.css';

/**
 * DEMO: formulario de login sin autenticación real.
 * Para producción: implementar POST + sesión/JWT con middleware Astro SSR.
 * NO usar method="GET" con credenciales en producción.
 */
---

<Layout title="Iniciar Sesión">
  <div class="LoginPage">
    <div class="LoginPage-inner">
      <header class="LoginPage-header">
        <a href="/" class="LoginPage-logo">
          <Logo />
        </a>
        <h1 class="LoginPage-title">Iniciar sesión</h1>
        <p class="LoginPage-demoBadge" role="note">
          ⚠ Modo demo — cualquier credencial redirige al dashboard
        </p>
      </header>

      <div class="LoginPage-card">
        {/* POST evita exponer credenciales en la URL; en demo redirige igual */}
        <form class="LoginPage-form" action="/dashboard" method="POST">
          <Input
            label="Usuario / Mail"
            type="email"
            placeholder="usuario@gmail.com"
            autoComplete="email"
            required
          />
          <Input label="Contraseña" type="password" placeholder="••••••••" autoComplete="current-password" required />

          <Button type="submit" fullWidth client:load>
            Ingresar
          </Button>
        </form>

        <p class="LoginPage-footer">
          ¿No tenés cuenta?{' '}
          <a href="#registro" class="LoginPage-link">
            Registrate
          </a>
          <span class="LoginPage-footerNote">(próximamente)</span>
        </p>

        <div class="LoginPage-google">
          {/* TODO: integrar OAuth en sprint siguiente */}
          <Button variant="outline" fullWidth type="button" disabled client:load>
            Acceso con Google (próximamente)
          </Button>
        </div>
      </div>
    </div>
  </div>
</Layout>
