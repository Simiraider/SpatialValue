---
import Layout from "../layouts/Layout.astro";
import { Button } from "../components/ui/Button";
import { Input } from "../components/ui/Input";
import Logo from "../components/Logo.astro";
---

<Layout title="Registrarse">
  <div class="auth-page">
    <div class="auth-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
      <div class="shape shape-4"></div>
    </div>
    <div class="auth-bg-overlay"></div>

    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-card-header">
          <a href="/" class="auth-logo">
            <Logo />
          </a>
          <h1 class="auth-title">Registrarse</h1>
        </div>

        <form class="auth-form" id="register-form">
          <Input
            label="Nombre completo"
            type="text"
            id="register-nombre"
            name="nombre"
            placeholder="Tu nombre completo"
            autoComplete="name"
            required
          />

          <Input
            label="Correo electrónico"
            type="email"
            id="register-email"
            name="email"
            placeholder="correo@ejemplo.com"
            autoComplete="email"
            required
          />

          <Input
            label="Contraseña"
            type="password"
            id="register-password"
            name="password"
            placeholder="Mínimo 8 caracteres"
            autoComplete="new-password"
            required
          />

          <Input
            label="Confirmar contraseña"
            type="password"
            id="register-password-confirm"
            name="password_confirm"
            placeholder="Repetí tu contraseña"
            autoComplete="new-password"
            required
          />

          <Button type="submit" fullWidth class="auth-submit-btn" client:load>Registrarse</Button>
        </form>

        <p class="auth-footer-text">
          ¿Ya tenés cuenta? <a href="/login" class="auth-link">Iniciá sesión</a>
        </p>

        <div class="auth-divider">
          <span class="auth-divider-line"></span>
          <span class="auth-divider-text">O continuá con</span>
          <span class="auth-divider-line"></span>
        </div>

        <div class="auth-social">
          <button type="button" class="auth-social-btn" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Continuar con Google
          </button>
          <button type="button" class="auth-social-btn" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#00a4ef" d="M11.5 2.5h5.5v5.5h-5.5z"/><path fill="#f25022" d="M2.5 2.5h5.5v5.5H2.5z"/><path fill="#ffb900" d="M2.5 12h5.5v5.5H2.5z"/><path fill="#7fba00" d="M11.5 12h5.5v5.5H11.5z"/></svg>
            Continuar con Microsoft
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById("register-form") as HTMLFormElement | null;
    const pwd = document.getElementById("register-password") as HTMLInputElement | null;
    const pwdConfirm = document.getElementById("register-password-confirm") as HTMLInputElement | null;

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (pwd && pwdConfirm && pwd.value !== pwdConfirm.value) {
        pwdConfirm.setCustomValidity("Las contraseñas no coinciden");
        pwdConfirm.reportValidity();
        return;
      } else {
        pwdConfirm?.setCustomValidity("");
      }

      const nombre = document.getElementById("register-nombre") as HTMLInputElement | null;
      const email = document.getElementById("register-email") as HTMLInputElement | null;
      if (!nombre || !email || !pwd) return;

      try {
        const body = {
          usuario: nombre.value.trim(),
          contraseña: pwd.value,
          email: email.value
        };

        const res = await fetch('/Apis/registro', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });

        if (!res.ok) {
          setTimeout(() => { window.location.href = '/login'; }, 1500);
          return;
        }

        const data = await res.json();

        if (res.ok && data.success) {
          setTimeout(() => { window.location.href = '/login'; }, 1500);
        } else {
          setTimeout(() => { window.location.href = '/login'; }, 1500);
        }

      } catch (error) {
        console.error("Error en la petición:", error);
        setTimeout(() => { window.location.href = '/login'; }, 1000);
      }
    });

    pwdConfirm?.addEventListener("input", () => {
      pwdConfirm.setCustomValidity("");
    });
  </script>
</Layout>

<style>
  .auth-page {
    display: flex;
    min-height: 100vh;
    position: relative;
    background: #f3f4f6;
    overflow: hidden;
  }

  .auth-bg-shapes {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .shape {
    position: absolute;
    opacity: 0.6;
  }

  .shape-1 {
    width: 35%;
    height: 45%;
    top: -10%;
    right: -5%;
    background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%);
    transform: skewY(-8deg);
    border-radius: 2rem;
  }

  .shape-2 {
    width: 25%;
    height: 35%;
    bottom: 15%;
    left: -8%;
    background: linear-gradient(225deg, #e5e7eb 0%, #d1d5db 100%);
    transform: skewX(12deg);
    border-radius: 3rem;
  }

  .shape-3 {
    width: 20%;
    height: 25%;
    bottom: -5%;
    right: 10%;
    background: linear-gradient(180deg, #f3f4f6 0%, #e5e7eb 100%);
    transform: rotate(-15deg);
    border-radius: 50% 50% 0 0;
  }

  .shape-4 {
    width: 15%;
    height: 20%;
    top: 30%;
    left: 20%;
    background: linear-gradient(90deg, #e5e7eb 0%, #d1d5db 100%);
    transform: rotate(25deg);
    border-radius: 1rem;
  }

  .auth-bg-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('/bg-logo.png');
    background-size: cover;
    background-position: center;
    opacity: 0.08;
    pointer-events: none;
    z-index: 1;
  }

  .auth-container {
    width: 100%;
    max-width: 26rem;
    margin: auto;
    padding: 2rem 1rem;
    position: relative;
    z-index: 2;
  }

  .auth-card {
    background: #1e1e2a;
    border-radius: 1.25rem;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .auth-card-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 1.75rem;
  }

  .auth-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .auth-logo :deep(.logo-img) {
    width: 2.5rem;
    height: 2.5rem;
  }

  .auth-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
  }

  .auth-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .auth-submit-btn {
    height: 2.75rem !important;
    background: #ffffff !important;
    color: #0F172A !important;
    font-weight: 600 !important;
    border-radius: 0.5rem !important;
    font-size: 0.95rem !important;
  }

  .auth-submit-btn:hover:not(:disabled) {
    background: #f3f4f6 !important;
  }

  .auth-footer-text {
    margin: 1.25rem 0 0;
    font-size: 0.85rem;
    color: #9ca3af;
  }

  .auth-link {
