---
import Layout from "../layouts/Layout.astro";
import { Button } from "../components/ui/Button";
import { Input } from "../components/ui/Input";
import Logo from "../components/Logo.astro";
---

<Layout title="Crear cuenta">
  <div class="min-h-screen flex items-center justify-center p-4 bg-[#F5F5F5] bg-[url('/bg-logo.png')] bg-center bg-no-repeat bg-cover">
    <div class="w-full max-w-md bg-[#575656] text-white rounded-[2rem] p-8 sm:p-10 shadow-2xl relative overflow-hidden my-8">
      <header class="mb-8 text-center flex flex-col items-center">
        <a href="/" class="text-white mb-4 block scale-125">
          <Logo />
        </a>
        <h1 class="text-2xl font-bold text-white mb-2">Crear cuenta</h1>
        <p class="text-slate-400 text-sm" id="mensaje-estado">
          Empezá a tasar propiedades en segundos
        </p>
      </header>

      <form class="flex flex-col gap-5" id="register-form">
        <div class="flex gap-4">
          <div class="text-slate-300 w-1/2">
            <Input
              label="Nombre"
              type="text"
              id="register-nombre"
              name="nombre"
              placeholder="Juan"
              autoComplete="given-name"
              required
              client:load
              className="text-slate-900"
            />
          </div>
          <div class="text-slate-300 w-1/2">
            <Input
              label="Apellido"
              type="text"
              id="register-apellido"
              name="apellido"
              placeholder="García"
              autoComplete="family-name"
              required
              client:load
              className="text-slate-900"
            />
          </div>
        </div>

        <div class="text-slate-300">
          <Input
            label="Email"
            type="email"
            id="register-email"
            name="email"
            placeholder="usuario@gmail.com"
            autoComplete="email"
            required
            client:load
            className="text-slate-900"
          />
        </div>

        <div class="text-slate-300">
          <Input
            label="Contraseña"
            type="password"
            id="register-password"
            name="password"
            placeholder="Mínimo 8 caracteres"
            autoComplete="new-password"
            required
            client:load
            className="text-slate-900"
          />
        </div>

        <div class="text-slate-300">
          <Input
            label="Confirmar contraseña"
            type="password"
            id="register-password-confirm"
            name="password_confirm"
            placeholder="Repetí tu contraseña"
            autoComplete="new-password"
            required
            client:load
            className="text-slate-900"
          />
        </div>

        <p class="text-slate-400 text-xs text-center mt-2">
          Al registrarte aceptás nuestros{" "}
          <a href="#" class="text-cyan-400 hover:text-cyan-300 transition-colors">Términos de uso</a>
          {" "}y{" "}
          <a href="#" class="text-cyan-400 hover:text-cyan-300 transition-colors">Política de privacidad</a>.
        </p>

        <div class="mt-2">
          <Button type="submit" fullWidth variant="secondary" client:load id="register-submit">
            Crear cuenta
          </Button>
        </div>
      </form>

      <p class="mt-8 text-center text-slate-400 text-sm">
        ¿Ya tenés cuenta?{" "}
        <a href="/login" class="text-cyan-400 font-medium hover:text-cyan-300 transition-colors">Iniciá sesión</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("register-form") as HTMLFormElement | null;
  const pwd = document.getElementById("register-password") as HTMLInputElement | null;
  const pwdConfirm = document.getElementById("register-password-confirm") as HTMLInputElement | null;
  const nombre = document.getElementById("register-nombre") as HTMLInputElement | null;
  const apellido = document.getElementById("register-apellido") as HTMLInputElement | null;
  const email = document.getElementById("register-email") as HTMLInputElement | null;
  const mensajeEstado = document.getElementById("mensaje-estado") as HTMLElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (pwd && pwdConfirm && pwd.value !== pwdConfirm.value) {
      pwdConfirm.setCustomValidity("Las contraseñas no coinciden");
      pwdConfirm.reportValidity();
      return;
    } else {
      pwdConfirm?.setCustomValidity("");
    }

    if (!nombre || !apellido || !email || !pwd || !mensajeEstado) return;

    try {
      mensajeEstado.innerText = "Registrando usuario...";
      mensajeEstado.style.color = "#06b6d4";

      const body = {
        usuario: `${nombre.value} ${apellido.value}`.trim(),
        contraseña: pwd.value,
        email: email.value
      };

      const res = await fetch('/Apis/registro', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });

      if (!res.ok) {
        mensajeEstado.innerText = "⚠ Backend no disponible — modo demo: cuenta creada localmente";
        mensajeEstado.style.color = "#f59e0b";
        setTimeout(() => { window.location.href = '/login'; }, 1500);
        return;
      }

      const data = await res.json();

      if (res.ok && data.success) {
        mensajeEstado.innerText = "¡Cuenta creada con éxito! Redirigiendo...";
        mensajeEstado.style.color = "#10b981";
        setTimeout(() => { window.location.href = '/login'; }, 1500);
      } else {
        mensajeEstado.innerText = `❌ ${data.error || 'Error al crear la cuenta'}`;
        mensajeEstado.style.color = "#ef4444";
      }

    } catch (error) {
      console.error("Error en la petición:", error);
      if (mensajeEstado) {
        mensajeEstado.innerText = "⚠ Backend no disponible — modo demo: cuenta creada localmente";
        mensajeEstado.style.color = "#f59e0b";
        setTimeout(() => { window.location.href = '/login'; }, 1500);
      }
    }
  });

  pwdConfirm?.addEventListener("input", () => {
    pwdConfirm.setCustomValidity("");
  });
</script>
