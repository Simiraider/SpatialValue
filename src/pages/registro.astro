---
import Layout from "../layouts/Layout.astro";
import { Button } from "../components/ui/Button";
import { Input } from "../components/ui/Input";
import Logo from "../components/Logo.astro";
import "../styles/registro.css";

---

<Layout title="Crear cuenta">
  <div class="RegisterPage">
    <div class="RegisterPage-inner">
      <header class="RegisterPage-header">
        <a href="/" class="RegisterPage-logo">
          <Logo />
        </a>
        <h1 class="RegisterPage-title">Crear cuenta</h1>
        <p class="RegisterPage-subtitle" id="mensaje-estado">
          Empezá a tasar propiedades en segundos
        </p>
      </header>

      <div class="RegisterPage-card">
        <form class="RegisterPage-form" id="register-form">
          <div class="RegisterPage-row">
            <Input
              label="Nombre"
              type="text"
              id="register-nombre"
              name="nombre"
              placeholder="Juan"
              autoComplete="given-name"
              required
            />
            <Input
              label="Apellido"
              type="text"
              id="register-apellido"
              name="apellido"
              placeholder="García"
              autoComplete="family-name"
              required
            />
          </div>

          <Input
            label="Email"
            type="email"
            id="register-email"
            name="email"
            placeholder="usuario@gmail.com"
            autoComplete="email"
            required
          />

          <Input
            label="Contraseña"
            type="password"
            id="register-password"
            name="password"
            placeholder="Mínimo 8 caracteres"
            autoComplete="new-password"
            required
          />

          <Input
            label="Confirmar contraseña"
            type="password"
            id="register-password-confirm"
            name="password_confirm"
            placeholder="Repetí tu contraseña"
            autoComplete="new-password"
            required
          />

          <p class="RegisterPage-terms">
            Al registrarte aceptás nuestros{" "}
            <a href="#" class="RegisterPage-link">Términos de uso</a>
            {" "}y{" "}
            <a href="#" class="RegisterPage-link">Política de privacidad</a>.
          </p>

          <Button type="submit" fullWidth client:load id="register-submit">
            Crear cuenta
          </Button>
        </form>

        <p class="RegisterPage-footer">
          ¿Ya tenés cuenta?{" "}
          <a href="/login" class="RegisterPage-link">Iniciá sesión</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("register-form") as HTMLFormElement | null;
  const pwd = document.getElementById("register-password") as HTMLInputElement | null;
  const pwdConfirm = document.getElementById("register-password-confirm") as HTMLInputElement | null;
  const nombre = document.getElementById("register-nombre") as HTMLInputElement | null;
  const apellido = document.getElementById("register-apellido") as HTMLInputElement | null;
  const email = document.getElementById("register-email") as HTMLInputElement | null;
  const mensajeEstado = document.getElementById("mensaje-estado") as HTMLElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (pwd && pwdConfirm && pwd.value !== pwdConfirm.value) {
      pwdConfirm.setCustomValidity("Las contraseñas no coinciden");
      pwdConfirm.reportValidity();
      return;
    } else {
      pwdConfirm?.setCustomValidity("");
    }

    if (!nombre || !apellido || !email || !pwd || !mensajeEstado) return;

    try {
      mensajeEstado.innerText = "Registrando usuario...";
      mensajeEstado.style.color = "#3b82f6";

      const body = {
        usuario: `${nombre.value} ${apellido.value}`.trim(),
        contraseña: pwd.value,
        email: email.value
      };

      const res = await fetch('/Apis/registro', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });

      const data = await res.json();

      if (res.ok && data.success) {
        mensajeEstado.innerText = "¡Cuenta creada con éxito! Redirigiendo al login...";
        mensajeEstado.style.color = "#10b981";
        setTimeout(() => {
          window.location.href = '/login';
        }, 1500);
      } else {
        mensajeEstado.innerText = `❌ ${data.error || 'Error al crear la cuenta'}`;
        mensajeEstado.style.color = "#ef4444";
      }

    } catch (error) {
      console.error("Error en la petición:", error);
      if (mensajeEstado) {
        mensajeEstado.innerText = "❌ Error de conexión con el servidor.";
        mensajeEstado.style.color = "#ef4444";
      }
    }
  });

  pwdConfirm?.addEventListener("input", () => {
    pwdConfirm.setCustomValidity("");
  });
</script>
