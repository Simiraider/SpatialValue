---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const team = [
  {
    name: "Manuel Smulovitz",
    imageSrc: "/quienes-somos/manuel-smulovitz.png",
  },
  {
    name: "Liam Lutteral",
    imageSrc: "/quienes-somos/liam-lutteral.png",
  },
  {
    name: "Jonas Leiserson",
    imageSrc: "/quienes-somos/jonas-leiserson.png",
  },
  {
    name: "Simon Flomenboim",
    imageSrc: "/quienes-somos/simon-flomenboim.png",
  },
];
---

<Layout title="¿Quiénes Somos?">
  <Navbar />
  <main class="page-main">
    <section class="page-section">
      <h1 class="page-title">¿Quienes Somos?</h1>

      <div class="team-cards">
        {team.map((person) => (
          <div class="team-card">
            <img
              class="team-photo"
              src={person.imageSrc}
              alt={person.name}
              loading="lazy"
            />
            <h3 class="team-name">{person.name}</h3>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-main {
    min-height: calc(100vh - 4rem - 4rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .page-section {
    max-width: 960px;
    width: 100%;
    text-align: center;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #0F172A;
    margin: 0 0 2.5rem;
  }

  .team-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .team-photo {
    width: 100%;
    max-width: 12rem;
    aspect-ratio: 0.8;
    border-radius: 1rem;
    background: #d1d5db;
    object-fit: cover;
  }

  .team-name {
    font-size: 1rem;
    font-weight: 600;
    color: #0F172A;
    margin: 0;
  }

  @media (max-width: 900px) {
    .team-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .team-cards {
      grid-template-columns: 1fr;
    }

    .team-photo {
      max-width: 10rem;
    }
  }
</style>
