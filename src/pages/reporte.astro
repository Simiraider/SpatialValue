---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/ui/Button';
import { ValorM2CacChart } from '../components/ReportCharts';
import { reporteMock } from '../data/mock';
import { Download } from 'lucide-react';
import '../styles/reporte.css';
---

<Layout title="Reporte de tasación">
  <div class="ReportePage">
    <header class="ReportePage-header">
      <div class="ReportePage-headerInner">
        <div>
          <p class="ReportePage-meta">ID: {reporteMock.id} · {reporteMock.fecha}</p>
          <h1 class="ReportePage-title">Reporte final</h1>
        </div>
        <Button variant="outline" client:load>
          <Download className="ReportePage-downloadIcon" />
          Descargar PDF
        </Button>
      </div>
    </header>

    <main class="ReportePage-main">
      <section class="ReportePage-valueCard">
        <p class="ReportePage-valueLabel">Valor total</p>
        <p class="ReportePage-valueUsd">
          {reporteMock.valorUsd} USD
        </p>
        <p class="ReportePage-valueArs">
          {reporteMock.valorArs} ARS
        </p>
      </section>

      <section class="ReportePage-section">
        <h2 class="ReportePage-sectionTitle">Valor de m² / Comparación con CAC</h2>
        <p class="ReportePage-sectionSubtitle">{reporteMock.valorM2Usd} USD/m² estimado</p>
        <ValorM2CacChart client:load />
      </section>

      <section class="ReportePage-section">
        <h2 class="ReportePage-sectionTitle">Propiedades similares</h2>
        <div class="ReportePage-mapPlaceholder">
          Mapa con comparables — integración en sprint posterior (scraping / API).
        </div>
      </section>

      <div class="ReportePage-actions">
        <a href="/dashboard">
          <Button client:load>Volver al Dashboard</Button>
        </a>
      </div>
    </main>
  </div>
</Layout>
