---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Nueva Tasacion - Spatial Value" showSidebar={true}>
  <section class="valuation">
    <div class="valuation-header">
      <h1 class="valuation-title">Nueva Tasacion</h1>
      <p class="valuation-subtitle">Completa los datos del inmueble para generar la tasacion</p>
    </div>

    <form class="valuation-form" action="/api/valuations" method="POST">
      <div class="form-section">
        <h2 class="form-section-title">Datos del Inmueble</h2>

        <div class="form-grid">
          <div class="form-group">
            <label for="address" class="form-label">Direccion</label>
            <input
              type="text"
              id="address"
              name="address"
              class="form-input"
              placeholder="Av. Corrientes 1234, CABA"
              required
            />
          </div>

          <div class="form-group">
            <label for="property_type" class="form-label">Tipo de Inmueble</label>
            <select id="property_type" name="property_type" class="form-input" required>
              <option value="">Seleccionar...</option>
              <option value="departamento">Departamento</option>
              <option value="casa">Casa</option>
              <option value="oficina">Oficina</option>
              <option value="local">Local Comercial</option>
              <option value="terreno">Terreno</option>
            </select>
          </div>

          <div class="form-group">
            <label for="surface" class="form-label">Superficie (m2)</label>
            <input
              type="number"
              id="surface"
              name="surface"
              class="form-input"
              placeholder="85"
              min="1"
              required
            />
          </div>

          <div class="form-group">
            <label for="rooms" class="form-label">Ambientes</label>
            <input
              type="number"
              id="rooms"
              name="rooms"
              class="form-input"
              placeholder="3"
              min="1"
            />
          </div>

          <div class="form-group">
            <label for="year_built" class="form-label">Ano de Construccion</label>
            <input
              type="number"
              id="year_built"
              name="year_built"
              class="form-input"
              placeholder="2005"
              min="1900"
              max="2026"
            />
          </div>

          <div class="form-group">
            <label for="condition" class="form-label">Estado</label>
            <select id="condition" name="condition" class="form-input">
              <option value="">Seleccionar...</option>
              <option value="excelente">Excelente</option>
              <option value="bueno">Bueno</option>
              <option value="regular">Regular</option>
              <option value="a_refaccionar">A Refaccionar</option>
            </select>
          </div>
        </div>
      </div>

      <div class="form-section">
        <h2 class="form-section-title">Observaciones</h2>
        <textarea
          name="notes"
          class="form-textarea"
          rows="4"
          placeholder="Detalles adicionales sobre el inmueble..."
        ></textarea>
      </div>

      <div class="form-actions">
        <button type="button" class="btn btn-secondary">Guardar Borrador</button>
        <button type="submit" class="btn btn-primary">Generar Tasacion</button>
      </div>
    </form>
  </section>
</MainLayout>

<style>
  .valuation {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 48rem;
  }

  .valuation-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .valuation-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }

  .valuation-subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .form-section {
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  .form-section-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .form-input,
  .form-textarea {
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s ease;
    font-family: inherit;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-soft);
  }

  .form-textarea {
    resize: vertical;
    width: 100%;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-primary {
    color: white;
    background: var(--color-primary);
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-secondary {
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-surface-hover);
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .form-actions {
      flex-direction: column;
    }
  }
</style>
